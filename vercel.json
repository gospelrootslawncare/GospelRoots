{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "framework": "create-react-app",
      "buildCommand": "yarn build",
      "outputDirectory": "build",
      "installCommand": "yarn install",
      "rewrites": [
        { "source": "/(.*)", "destination": "/index.html" }
      ]
    },
    "backend": {
      "root": "backend",
      "framework": "fastapi",
      "path": "/_/backend"
    }
  }
}
